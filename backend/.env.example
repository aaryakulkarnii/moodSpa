# ── Neon PostgreSQL (free) ──────────────────────────────────
# Get from: neon.tech → New Project → copy connection string
# Looks like: postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require
DATABASE_URL=your_neon_postgresql_url_here

# ── Gemini AI (free) ─────────────────────────────────────────
# Get from: aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ── Server ───────────────────────────────────────────────────
PORT=5000
FRONTEND_URL=http://localhost:5173
